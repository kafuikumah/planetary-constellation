{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/benchmarking/layout,_N_T_/benchmarking/page,_N_T_/benchmarking"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/benchmarking/__PAGE__",
    "/benchmarking",
    "/_index",
    "/_head"
  ]
}